{
  "name": "memu-guardian",
  "description": "memu-server daily maintenance agent",
  "note": "Uses OpenCode built-in free models, no API key needed",
  "models": [
    "Big Pickle OpenCode Zen",
    "DeepSeek V4 Flash Free OpenCode Zen",
    "North Mini Code Free OpenCode Zen",
    "Nemotron 3 Ultra Free",
    "MiMo V2.5 Free"
  ],
  "system_prompt_file": "./config/guardian-system-prompt.md",
  "mcp_servers": {
    "memu": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "/Users/myking/memu",
        "python",
        "-m",
        "memu.mcp"
      ],
      "env": {}
    }
  },
  "max_turns": 20,
  "auto_approve": true
}
