{
  "name": "memu-guardian",
  "description": "memu-server daily maintenance agent",
  "model": {
    "provider": "openrouter",
    "name": "google/gemini-2.0-flash-exp:free",
    "api_key_env": "OPENROUTER_API_KEY"
  },
  "fallback_models": [
    {
      "provider": "openrouter",
      "name": "meta-llama/llama-3.3-70b-instruct:free",
      "api_key_env": "OPENROUTER_API_KEY"
    },
    {
      "provider": "openrouter",
      "name": "qwen/qwen-2.5-72b-instruct:free",
      "api_key_env": "OPENROUTER_API_KEY"
    }
  ],
  "system_prompt_file": "./config/guardian-system-prompt.md",
  "mcp_servers": {
    "memu": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "/Users/myking/memu",
        "python",
        "-m",
        "memu.mcp"
      ],
      "env": {}
    }
  },
  "max_turns": 20,
  "auto_approve": true
}
