# memu-server environment variables
# Copy to .env and fill in your values

# LLM configuration (reuses the same env vars as other tools)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
MEMU_CHAT_MODEL=gpt-4o-mini
MEMU_EMBED_MODEL=text-embedding-3-small

# Database path (default: ~/.memu/unified.db)
# MEMU_DB_PATH=/Users/myking/.memu/unified.db

# Blob/resource storage (default: ~/.memu/resources)
# MEMU_BLOB_DIR=/Users/myking/.memu/resources

# Default user ID written to all memory records
MEMU_USER_ID=myking
